# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/

# Testing
.pytest_cache/
.coverage
# Dashboard test-suite per-run reports (the .gitkeep is committed; everything
# else is generated at test time and would just create noise in PRs).
tests/dashboard/reports/*
!tests/dashboard/reports/.gitkeep
# Earlier ``lib/`` Python-build pattern accidentally swallows the dashboard
# test-suite's lib package — explicitly un-ignore source files. Bytecode
# stays gitignored via the global __pycache__/ rule.
!tests/dashboard/lib/
!tests/dashboard/lib/*.py
tests/dashboard/lib/__pycache__/
htmlcov/
.tox/
.nox/

# IDEs
.idea/
.vscode/
*.swp
*.swo
*~

# Claude Code worktrees
.claude/worktrees/

# Environment
.env

# Data (keep structure, ignore large files)
data/raw
data/processed/*.duckdb
data/processed/*.rdf
data/processed/*.pt
data/features/*.parquet
data/features/*.csv

# Generated outputs
outputs/
cloud_outputs/

# Ontology outputs
ontology/output/*.ttl
ontology/output/*.owl
ontology/output/*.nt

# Notebooks
notebooks/.ipynb_checkpoints/
*.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# uv lock file
uv.lock
